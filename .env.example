# Required: Supabase Postgres connection string.
# IMPORTANT: For Vercel/serverless, use Supabase's POOLED connection string (Transaction mode, port 6543).
# Find it in: Supabase project → Settings → Database → Connection string → "Transaction" pooler.
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Required: admin login password for /admin
ADMIN_PASSWORD=Admin123#

# Optional: secret used to sign session cookies (any long random string).
JWT_SECRET=change-me-to-a-long-random-string

# Optional: server port for local dev (defaults to 3000).
PORT=3000
